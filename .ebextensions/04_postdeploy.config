commands:
  01_create_postdeploy_hook:
    command: |
      mkdir -p /opt/elasticbeanstalk/hooks/appdeploy/post
      cat > /opt/elasticbeanstalk/hooks/appdeploy/post/99_prisma.sh << 'EOF'
      #!/bin/bash
      cd /var/app/current
      npm install --legacy-peer-deps --silent 2>&1 | tail -20
      npx prisma generate --silent 2>&1 | tail -10
      EOF
      chmod +x /opt/elasticbeanstalk/hooks/appdeploy/post/99_prisma.sh
